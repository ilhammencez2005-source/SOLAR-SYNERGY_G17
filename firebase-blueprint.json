{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and wallet information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique identifier for the user" },
        "email": { "type": "string", "format": "email", "description": "User's email address" },
        "displayName": { "type": "string", "description": "User's full name" },
        "walletBalance": { "type": "number", "description": "Current balance in RM" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation timestamp" }
      },
      "required": ["uid", "email", "walletBalance"]
    },
    "Station": {
      "title": "Station",
      "description": "Charging hub details",
      "type": "object",
      "properties": {
        "id": { "type": "integer" },
        "name": { "type": "string" },
        "address": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Occupied"] },
        "slots": { "type": "integer" },
        "totalSlots": { "type": "integer" },
        "coordinates": { "type": "string" }
      },
      "required": ["id", "name", "status"]
    },
    "Session": {
      "title": "Session",
      "description": "Active or historical charging session",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "stationId": { "type": "integer" },
        "startTime": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["reserving", "charging", "completed", "overstay"] },
        "chargeLevel": { "type": "number" },
        "cost": { "type": "number" },
        "energyConsumed": { "type": "number" }
      },
      "required": ["uid", "stationId", "startTime", "status"]
    },
    "IssueReport": {
      "title": "IssueReport",
      "description": "Hardware issue reported by a user",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "category", "description", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile data"
    },
    "/stations/{stationId}": {
      "schema": "Station",
      "description": "Station status and information"
    },
    "/sessions/{sessionId}": {
      "schema": "Session",
      "description": "Charging session records"
    },
    "/reports/{reportId}": {
      "schema": "IssueReport",
      "description": "User-submitted issue reports"
    }
  }
}
